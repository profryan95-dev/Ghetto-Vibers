<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ghetto Viber's Media</title>
<style>
  :root{ --red:#e10000; --dark:#0a0a0a; --gray:#111; --text:#fff; }
  *{margin:0;padding:0;box-sizing:border-box;font-family:Arial,Helvetica,sans-serif}
  body{background:var(--dark);color:var(--text)}
  a{text-decoration:none;color:inherit}
  .container{max-width:1200px;margin:auto;padding:0 20px}
  header{background:#000;padding:12px 0;position:sticky;top:0;z-index:10}
  nav{display:flex;align-items:center;justify-content:space-between;gap:20px}
  .logo{display:flex;align-items:center;gap:10px;font-weight:800}
  .logo span{background:var(--red);color:#fff;padding:4px 8px;border-radius:4px;font-size:20px}
  nav ul{display:flex;gap:20px;list-style:none;font-size:14px}
  nav ul li a.active{color:var(--red);border-bottom:2px solid var(--red)}
  .phone{color:var(--red);font-weight:700;font-size:14px}
  .hero{background:linear-gradient(90deg, rgba(0,0,0,0.8), rgba(225,0,0,0.3)), url('https://images.unsplash.com/photo-1514525253161-7a46d19f8154?q=80&w=1200') center/cover no-repeat; padding:80px 0;}
  .hero h1{font-size:48px;line-height:1.1} .hero h1 span{color:var(--red)}
  .hero p{max-width:400px;margin:12px 0 20px;opacity:0.9}
  .btns{display:flex;gap:12px}
  .btn{background:var(--red);color:#fff;padding:12px 20px;border:none;border-radius:4px;font-weight:700;cursor:pointer}
  .btn.outline{background:transparent;border:1px solid #fff}
  .artists-row{display:flex;gap:0;overflow-x:auto;margin-top:40px}
  .artist-card{min-width:250px;text-align:center;position:relative}
  .artist-card img{width:100%;height:320px;object-fit:cover;filter:brightness(0.9)}
  .artist-card .name{position:absolute;bottom:0;left:0;right:0;background:var(--red);padding:8px;font-weight:700}
  section{padding:60px 0}
  .title{text-align:center;margin-bottom:30px;font-size:22px;font-weight:800;letter-spacing:1px}
  .title .star{color:var(--red)}
  .featured{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:20px}
  .card{background:#1a1a1a;border-radius:8px;overflow:hidden;text-align:center}
  .card img{width:100%;height:220px;object-fit:cover}
  .card h3{margin:12px 0 6px}
  .card p{font-size:14px;opacity:0.8;padding:0 10px}
  .card .btn{margin:12px 0}
  .music{background:var(--gray)}
  .music-wrap{display:grid;grid-template-columns:2fr 1fr;gap:40px;align-items:start}
  .player{background:#000;padding:20px;border-radius:8px}
  .track{display:flex;align-items:center;gap:10px;margin:8px 0;font-size:14px}
  .track .download{margin-left:auto;color:var(--red)}
  .grid4{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-top:20px}
  .grid4 div{background:#1a1a1a;padding:20px;border-radius:8px;text-align:center}
  footer{background:#000;padding:40px 0;font-size:14px}
  .footer-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:30px}
  footer h4{color:var(--red);margin-bottom:10px}
  footer ul{list-style:none}
  footer ul li{margin:6px 0}
  .newsletter input{padding:10px;width:100%;border:none;border-radius:4px;margin-bottom:8px}
  .copy{text-align:center;border-top:1px solid #222;margin-top:30px;padding-top:20px;opacity:0.7}
  @media(max-width:900px){.music-wrap{grid-template-columns:1fr} nav ul{display:none}}
</style>
</head>
